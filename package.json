{
  "name": "study-eng-h",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "content:validate:quiz": "tsx prisma/scripts/validate-quiz-source.ts",
    "content:build:quiz": "tsx prisma/scripts/build-quiz-artifact.ts",
    "content:validate:vocabulary": "tsx prisma/scripts/validate-vocabulary-source.ts",
    "content:build:vocabulary": "tsx prisma/scripts/build-vocabulary-artifact.ts",
    "content:report:collisions": "tsx prisma/scripts/report-content-collisions.ts",
    "content:report:coverage": "tsx prisma/scripts/report-content-coverage.ts",
    "content:build": "npm run content:build:vocabulary && npm run content:build:quiz",
    "content:check": "npm run content:validate:vocabulary && npm run content:validate:quiz && npm run content:report:collisions && npm run content:report:coverage && npm run content:build",
    "content:seed:vocabulary": "tsx prisma/seed-vocabulary.ts",
    "content:seed:quiz": "tsx prisma/seed-quiz.ts",
    "content:seed:quiz:reset": "tsx prisma/seed-quiz.ts --reset",
    "content:seed": "npm run content:check && npm run content:seed:vocabulary && npm run content:seed:quiz"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@tanstack/react-query": "^5.90.20",
    "@types/pg": "^8.16.0",
    "better-auth": "^1.4.18",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "pg": "^8.18.0",
    "prisma": "^7.3.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^2.15.4",
    "tailwind-merge": "^3.4.0",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1083.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "happy-dom": "^20.10.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
